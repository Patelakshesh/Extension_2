{
  "manifest_version": 3,
  "name": "B2B Master Lead Scraper (Secure)",
  "version": "2.0",
  "description": "Scrapes Google Maps leads. Gets both with and without websites. Skips leads with no contact info.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://www.google.com/maps/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.google.com/maps/*"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
